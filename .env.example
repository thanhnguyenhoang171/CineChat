# ==========================================
# CINECHAT MASTER ENV EXAMPLE
# Copy nội dung này vào các file .env tương ứng trong thư mục apps/
# ==========================================

# --- BACKEND (apps/backend/.env) ---
# PORT=3001
# MONGODB_URI=mongodb://localhost:27017/cinechat
# JWT_SECRET=your_very_secret_key
# CLOUDINARY_URL=...

# --- ADMIN CONSOLE (apps/admin-console/.env) ---
# VITE_API_URL=http://localhost:3001/api/v1
# VITE_APP_NAME=CineChat Admin

# --- USER CONSOLE (apps/user-console/.env) ---
# NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
